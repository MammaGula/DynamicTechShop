@page "/products"
@using DynamicTechShop.Shared.Models
@inject DynamicTechShop.Client.Services.ProductService ProductService
@inject NavigationManager Nav

<h3>Products</h3>

<input class="form-control" placeholder="Search..."
       @bind="searchText" @bind:event="oninput" /> 
       @* Specify that the searchText should be updated when an oninput event occurs (each time the user types). *@

<div class="row mt-3">
    @foreach (var p in GetFilteredProducts())
    {
        <div class="col-12 col-md-6 col-lg-4 mb-4">
            <div class="card h-100 product-card" style="cursor:pointer; transition: all 0.3s ease; border-radius: 12px; overflow: hidden;" @onclick="() => OpenProduct(p.Id)">
                <div style="height: 280px; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%); padding: 20px;">
                    <img src="@p.ImageUrl" alt="@p.Name"
                         style="max-width: 100%; max-height: 100%; object-fit: contain; transition: transform 0.3s ease; filter: drop-shadow(0 4px 12px rgba(0,0,0,0.15));" 
                         class="product-img" />
                </div>
                <div class="card-body" style="padding: 1.5rem; background: white;">
                    <h5 class="card-title mb-2" style="font-size: 1.15rem; font-weight: 600; color: #2c3e50;">@p.Name</h5>
                    <div class="text-muted small mb-3" style="text-transform: uppercase; letter-spacing: 0.5px; font-size: 0.8rem;">@p.Category</div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-bold" style="font-size: 1.4rem; color: #198754;">$@p.Price.ToString("0.00")</span>
                        <span class="badge bg-primary" style="padding: 0.5rem 1rem;">View Details</span>
                    </div>
                </div>
            </div>
        </div>
    }
</div>






<style>
    .product-card {
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        border: none;
    }

    .product-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 12px 24px rgba(0,0,0,0.15) !important;
    }

    .product-card:hover .product-img {
        transform: scale(1.08);
    }

    .product-card:hover .badge {
        background-color: #0d6efd !important;
    }
</style>

@code {


    private List<ProductModel> products = new();
    private string searchText = "";


    // Load products when the component initializes.
    protected override async Task OnInitializedAsync()
    {
        products = await ProductService.GetProductsAsync();
    }


    // Return products filtered by the current search text.
    // Keeps the UI code simple by moving the logic here.
    private IEnumerable<ProductModel> GetFilteredProducts()
    {
        // If search text is empty, return all products(All products returns at start)
        if (string.IsNullOrWhiteSpace(searchText))
        {
            return products;
        }

        // Filter products by name or category, ignoring case.
        var query = searchText.Trim();
        return products.Where(p =>
            p.Name.Contains(query, StringComparison.OrdinalIgnoreCase) ||
            p.Category.Contains(query, StringComparison.OrdinalIgnoreCase));
    }


    // Navigate to the product details page when a product card is clicked.
    private void OpenProduct(int id)
    {
        Nav.NavigateTo($"/products/{id}");
    }
}