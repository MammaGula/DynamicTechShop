@page "/cart"
@inject DynamicTechShop.Client.Services.CartService CartService
@inject NavigationManager Nav

<h3>Cart</h3>

@if (CartService.Items.Count == 0)
{
    <p>Your cart is empty.</p>
}

else
{
    <ul class="list-group">
        @foreach (var item in CartService.Items)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-3">
                    <img src="@item.ImageUrl" alt="@item.Name" style="width:70px;height:50px;object-fit:cover;" />
                    <div>
                        <div class="fw-bold">@item.Name</div>
                        <small class="text-muted">@item.Price.ToString("0.00")</small>
                    </div>
                </div>

                <button class="btn btn-sm btn-outline-danger" @onclick="() => Remove(item.Id)">Remove</button>
            </li>
        }
    </ul>

    <div class="mt-3 fw-bold">
        Total: @CartService.Total.ToString("0.00")
    </div>

    <div class="mt-3 d-flex gap-2">
        <button class="btn btn-success" @onclick="GoToCheckout">Go to checkout</button>
        <button class="btn btn-outline-secondary" @onclick="ContinueShopping">Continue shopping</button>
    </div>
}




@code {
    private async Task Remove(int id) => await CartService.RemoveAsync(id);
    
    private void GoToCheckout() => Nav.NavigateTo("/checkout");
    
    private void ContinueShopping() => Nav.NavigateTo("/products");
}

