@page "/products/{Id:int}"
@using DynamicTechShop.Shared.Models
@inject DynamicTechShop.Client.Services.ProductService ProductService
@inject DynamicTechShop.Client.Services.CartService CartService
@inject NavigationManager Nav

@if (product is null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <div class="container py-4">
        <div class="row">
            <div class="col-lg-6 mb-4">
                <div class="product-detail-image" style="background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%); border-radius: 16px; padding: 40px; display: flex; align-items: center; justify-content: center; min-height: 500px;">
                    <img src="@product.ImageUrl" alt="@product.Name"
                         style="max-width: 100%; max-height: 500px; object-fit: contain; filter: drop-shadow(0 8px 24px rgba(0,0,0,0.15));" />
                </div>
            </div>
            <div class="col-lg-6">
                <div class="product-detail-info">
                    <div class="badge bg-secondary mb-3" style="text-transform: uppercase; letter-spacing: 1px; font-size: 0.75rem; padding: 0.5rem 1rem;">
                        @product.Category
                    </div>
                    <h2 class="mb-3" style="font-weight: 700; color: #2c3e50; font-size: 2rem;">@product.Name</h2>
                    <div class="mb-4" style="font-size: 2.5rem; font-weight: 700; color: #198754;">
                        $@product.Price.ToString("0.00")
                    </div>
                    <div class="mb-4 pb-4" style="border-bottom: 2px solid #e9ecef;">
                        <h5 class="mb-3" style="font-weight: 600; color: #495057;">Description</h5>
                        <p style="color: #6c757d; line-height: 1.8; font-size: 1rem;">@product.Description</p>
                    </div>

                    <div class="d-flex gap-3 flex-wrap">
                        <button class="btn btn-primary btn-lg px-5" @onclick="AddToCart" style="font-weight: 600; border-radius: 8px;">
                            <i class="bi bi-cart-plus me-2"></i>Add to Cart
                        </button>
                        <button class="btn btn-outline-secondary btn-lg px-4" @onclick='() => Nav.NavigateTo("/products")' style="border-radius: 8px;">
                            <i class="bi bi-arrow-left me-2"></i>Back to Products
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}




@code {
    [Parameter] public int Id { get; set; }
    private ProductModel? product;

    // Load the product details when the component parameters are set (when Id changes).
    protected override async Task OnParametersSetAsync()
    {
        product = await ProductService.GetByIdAsync(Id);
    }

    private async Task AddToCart()
    {
        if (product is null) return; // If product is not loaded, do nothing.
        await CartService.AddAsync(product);
        Nav.NavigateTo("/cart");
    }
}